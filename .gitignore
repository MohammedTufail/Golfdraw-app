# WHY: These files should never be committed to git

# Dependencies — too large, regenerated via npm install
node_modules/
.pnp
.pnp.js

# Build output — generated by next build, not source
.next/
out/
build/

# Environment files — CONTAIN SECRETS
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel deployment metadata
.vercel

# TypeScript build cache
*.tsbuildinfo
next-env.d.ts

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*